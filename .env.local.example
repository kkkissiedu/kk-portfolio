# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives contact form submissions
RESEND_TO_EMAIL=hello@theanthracite.com

# ─── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# ─── Sanity Webhook Revalidation ──────────────────────────────────────────────
# Generate a strong random secret (e.g. openssl rand -hex 32) and add the same
# value to your Sanity webhook configuration under "HTTP Headers":
#   x-sanity-webhook-secret: <your_secret>
SANITY_REVALIDATE_SECRET=your_webhook_secret
